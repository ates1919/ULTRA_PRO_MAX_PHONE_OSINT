# === ULTRA PRO MAX PHONE OSINT ===
# Bu dosyayı .env olarak kopyalayın

# API Anahtarları (Opsiyonel)
TRUE_CALLER_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Sistem Ayarları
DEBUG=False
LOG_LEVEL=INFO

# Analiz Ayarları
DEEP_SCAN=False
TIMEOUT=15
MAX_RETRIES=2

# Proxy (Opsiyonel)
USE_PROXY=False
PROXY_HTTP=http://proxy:8080
